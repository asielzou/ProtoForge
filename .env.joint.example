# ProtoForge + EdgeLite 联合部署环境变量模板
#
# 使用方法：
#   1. 复制本文件为 .env.joint：  cp .env.joint.example .env.joint
#   2. 将所有 change_me_* 占位符替换为真实强密码（生产环境务必！）
#   3. 启动联合栈：  docker compose -f docker-compose.joint.yml --env-file .env.joint up -d
#
# 注意：
#   - PROTOFORGE_DB_PATH 中的密码必须与 PROTOFORGE_DB_PASSWORD 一致
#   - SECRET_KEY / PROTOFORGE_JWT_SECRET 建议至少 32 字符
#   - INFLUXDB_TOKEN 建议至少 16 字符

# ── ProtoForge（工业设备仿真平台）──
PROTOFORGE_DB_PASSWORD=change_me_pg_password
PROTOFORGE_DB_PATH=postgresql://protoforge:change_me_pg_password@postgres:5432/protoforge
PROTOFORGE_JWT_SECRET=change_me_jwt_secret_at_least_32_chars
PROTOFORGE_ADMIN_PASSWORD=change_me_admin_password
PROTOFORGE_CORS_ORIGINS=http://localhost:8000,http://localhost:8081

# ── EdgeLite（边缘网关）──
EDGELITE_ADMIN_PASSWORD=change_me_edgelite_admin
ADMIN_RESET_PASSWORD=false
SECRET_KEY=change_me_edgelite_secret_at_least_32_chars

# ── InfluxDB（EdgeLite 时序数据库）──
INFLUXDB_USERNAME=edgelite
INFLUXDB_PASSWORD=change_me_influx_password
INFLUXDB_TOKEN=change_me_influx_token_at_least_16_chars

# ── MQTT（EdgeLite 消息代理）──
MQTT_PASSWORD=change_me_mqtt_password

# ── EdgeLite 构建路径（相对 ProtoForge 根目录，用于挂载 mosquitto.conf 与构建镜像）──
EDGELITE_PATH=../EdgeLite/EdgeLite-v1.0-Community
