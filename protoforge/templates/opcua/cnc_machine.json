            "access": "r",
            "generator_type": "random",
            "min_value": -500,
            "max_value": 500
        },
        {
            "name": "y_position",
            "address": "ns=2;s=YPosition",
            "data_type": "float32",
            "unit": "mm",
            "description": "Y轴坐标",
            "access": "r",
            "generator_type": "random",
            "min_value": -300,
            "max_value": 300
        },
        {
            "name": "z_position",
            "address": "ns=2;s=ZPosition",
