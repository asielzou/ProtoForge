{
    "id": "modbus_temp_sensor",
    "name": "温湿度传感器",
    "protocol": "modbus_tcp",
    "description": "工业级温湿度传感器，支持温湿度采集和告警",
    "manufacturer": "Generic",
    "model": "TH-200",
    "points": [
        {
            "name": "temperature",
            "address": "0",
            "data_type": "float32",
            "unit": "°C",
            "description": "环境温度",
            "access": "r",
            "generator_type": "random",
            "min_value": 15.0,
            "max_value": 35.0
        },
        {
            "name": "humidity",
            "address": "1",
            "data_type": "float32",
            "unit": "%RH",
            "description": "相对湿度",
            "access": "r",
            "generator_type": "random",
            "min_value": 30.0,
            "max_value": 80.0
        },
        {
            "name": "dew_point",
            "address": "2",
            "data_type": "float32",
            "unit": "°C",
            "description": "露点温度",
            "access": "r",
            "generator_type": "random",
            "min_value": 5.0,
            "max_value": 25.0
        },
        {
            "name": "alarm_status",
            "address": "3",
            "data_type": "uint16",
            "description": "告警状态(0=正常 1=高温 2=高湿)",
            "access": "r",
            "generator_type": "fixed",
            "fixed_value": 0
        }
    ],
    "protocol_config": {
        "slave_id": 1
    },
    "tags": [
        "传感器",
        "温湿度",
        "Modbus",
        "环境监测"
    ]
}